{
  "id": "on-ont-on-n",
  "title": "on · ont · on n'",
  "shortTitle": "on / ont / on n'",
  "description": "Distinguer : on (pronom sujet = il/elle), ont (verbe avoir, ils/elles), on n' (on ne, négation devant voyelle).",

  "choices": [
    { "id": "on",   "label": "on",    "isVerbe": false, "negatif": false },
    { "id": "ont",  "label": "ont",   "isVerbe": true,  "negatif": false },
    { "id": "onn",  "label": "on n'", "isVerbe": false, "negatif": true  }
  ],

  "decisionAxes": [
    {
      "id": "isVerbe",
      "question": "Est-ce le verbe avoir ?",
      "sub": "Test : remplace par « avaient »",
      "options": [
        { "value": true,  "label": "Oui → ont", "sub": "ils avaient → fonctionne", "eliminates": ["on","onn"] },
        { "value": false, "label": "Non → on ou on n'", "sub": "pronom sujet = il/elle", "eliminates": ["ont"] }
      ]
    },
    {
      "id": "negatif",
      "question": "La phrase est-elle négative (ne…pas) ?",
      "dependsOn": "isVerbe",
      "showWhen": false,
      "options": [
        { "value": true,  "label": "Oui, négation devant voyelle → on n'", "eliminates": ["on"] },
        { "value": false, "label": "Non → on", "eliminates": ["onn"] }
      ]
    }
  ],

  "memoCard": {
    "title": "La règle en un coup d'œil",
    "rows": [
      { "form": "on",    "test": "pronom = il/elle",         "example": "On part demain." },
      { "form": "ont",   "test": "remplace par « avaient »", "example": "Ils ont fini. → Ils avaient fini. ✓" },
      { "form": "on n'", "test": "on ne + voyelle",          "example": "On n'a pas le temps." }
    ]
  },

