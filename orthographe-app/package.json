{
  "name": "orthographe-app",
  "private": true,
  "version": "0.1.039",
  "type": "module",
  "scripts": {
    "backend": "node server/local-api.mjs",
    "dev": "vite",
    "build": "node scripts/generate-seo-data.mjs && node scripts/generate-sitemap.mjs && vite build && node scripts/generate-seo-pages.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/local-api.mjs",
    "test:visual": "node tests/visual.test.js",
    "test:visual:local": "BASE_URL=http://localhost:5173 node tests/visual.test.js",
    "test:emotions": "BASE_URL=http://localhost:5173 node tests/emotion-rules.test.js",
    "test:characters": "BASE_URL=http://localhost:5173 node tests/characters-moods.test.js",
    "test:personas": "BASE_URL=http://localhost:5173 node tests/personas-flow.test.js",
    "test:pin": "BASE_URL=http://localhost:5173 node tests/pin-parental.test.js",
    "test:coaching": "node tests/coaching-banner.test.js",
    "test:coaching:update": "node tests/coaching-banner.test.js --update-snapshots",
    "test:auth": "BASE_URL=http://localhost:5173 node tests/auth-flow.test.js",
    "test:auth:real": "AUTH_REAL=1 BASE_URL=http://localhost:5173 node tests/auth-flow.test.js",
    "test:stats": "node tests/stats.test.js",
    "test:stats:e2e": "BASE_URL=http://localhost:5173 node tests/progress-charts.test.js",
    "test:end-screen": "BASE_URL=http://localhost:5173 node tests/end-screen-redesign.test.js",
    "test:unit": "node tests/runners/run-unit.js",
    "test:e2e": "node tests/runners/run-e2e.js",
    "test:all": "node tests/runners/run-unit.js && node tests/runners/run-e2e.js",
    "test:predeploy": "node tests/runners/run-predeploy.js",
    "deploy": "node scripts/bump-version.js && node tests/runners/run-predeploy.js && firebase deploy --only hosting",
    "deploy:raw": "firebase deploy --only hosting",
    "docs:capture": "node docs/capture-all.js"
  },
  "dependencies": {
    "@posthog/react": "^1.9.0",
    "@sentry/react": "^10.51.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "posthog-js": "^1.372.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "marked": "^18.0.3",
    "playwright": "^1.59.1",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0"
  }
}
